# Copy this file beside the GoDict executable and replace or export its credentials.
# This is Russian version of the file
settings { beep_on_completion = true }
speech {
  api_key          = "%api_key%"
  folder_id        = "%folder_id%"
  default_language = "Auto"
  languages = {
    Auto    = "auto"
    Russian = "ru-RU"
    English = "en-US"
  }
}

model "gpt" {
  model_name = "gpt-5.5"
  base_url   = "https://api.openai.com/v1"
  api_key    = "%OPENAI_API_KEY%"
  reasoning  = "low"
  params = { reasoning = { effort = "none" } }
}

model "fast" {
  model_name = "gpt-5.4-mini"
  base_url   = "https://api.openai.com/v1"
  api_key    = "%OPENAI_API_KEY%"
  reasoning  = "none"
  params = { reasoning = { effort = "none" } }
}

model "cheap" {
  model_name = "gpt-5.4-nano"
  base_url   = "https://api.openai.com/v1"
  api_key    = "%OPENAI_API_KEY%"
  params = { reasoning = { effort = "none" } }
}

model "yagpt" {
  model_name = "gpt://%folder_id%/yandexgpt-5.1"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
}

model "yagpt-pro" {
  model_name = "gpt://%folder_id%/yandexgpt-5-pro"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
}

model "qwen" {
  model_name = "gpt://%folder_id%/qwen3.6-35b-a3b"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
  default    = true
}

model "qwen3" {
  model_name = "gpt://%folder_id%/qwen3-235b-a22b-fp8"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
}

model "deepseek" {
  model_name = "gpt://%folder_id%/deepseek-v4-flash"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
}

model "alice" {
  model_name = "gpt://%folder_id%/aliceai-llm"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
}

model "alice-flash" {
  model_name = "gpt://%folder_id%/aliceai-llm-flash"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
}

template "коррекция" {
  text = <<-PROMPT
Исправь все типографические и пунктуационные ошибки в приведённом ниже надиктованном тексте.
Полностью сохрани значение, стиль и язык. Верни только исправленный текст.

{recognized_text}
PROMPT
}

template "профессиональный" {
  default = true
  text = <<-PROMPT
Ты - профессиональный редактор текстов с 20 годами опыта.
Преврати надиктованный пользователем фрагмент или идею текста в профессиональный редакторский текст. Сначала продумай хорошую структуру для изложения материала, затем напиши по этой структуре профессиональный текст. Сохраняй все факты, следуй указаниям пользователя. Эту инструкцию в тексте не упоминай.

{recognized_text}
PROMPT
}

template "python-программа" {
  text = <<-PROMPT
Создай законченную программу на Python по описанию пользователя ниже. Верни только исходный код в одном блоке без пояснений. Используй понятную структуру, обработку ошибок там, где она нужна, и комментарии на языке {language}.

Описание пользователя:
{recognized_text}
PROMPT
}

template "продолжи текст" {
  text = <<-PROMPT
Продолжи текст в том же стиле, тоне, лице и формате. Предыдущий фрагмент текста:

{clipboard}

Инструкция или направление для продолжения:
{recognized_text}

Верни только продолжение, не повторяя предыдущий фрагмент и не добавляя пояснений.
PROMPT
}

template "буфер обмена" {
  text = <<-PROMPT
В буфере обмена содержится следующий текст):

<clipboard>
{clipboard}
</clipboard>

Вот задание от пользователя, что нужно сделать с этим текстом:
{recognized_text}

Верни только результат, не повторяя предыдущий фрагмент и не добавляя пояснений.
PROMPT
}
