# English starter configuration. Copy it beside the executable as godict.config.
settings { beep_on_completion = true }
speech {
  api_key = "%api_key%"
  folder_id = "%folder_id%"
  default_language = "Auto"
  languages = { Auto = "auto", Russian = "ru-RU", English = "en-US" }
}
model "gpt" {
  model_name = "gpt-5.5"
  base_url = "https://api.openai.com/v1"
  api_key = "%OPENAI_API_KEY%"
  reasoning = "low"
  default = true
}
template "correct" {
  text = <<-PROMPT
Correct typographical and punctuation errors in the dictated text below. Preserve its meaning and language. Return only the corrected text.

{recognized_text}
PROMPT
}
template "professional" {
  default = true
  text = <<-PROMPT
You are a professional editor. Turn the dictated fragment or idea into polished, coherent text. Preserve facts and instructions. Return only the final text.

{recognized_text}
PROMPT
}
template "python-program" {
  text = <<-PROMPT
Create a complete Python program from the user description below. Return only source code in one block. Use comments in {language}.

User description:
{recognized_text}
PROMPT
}
template "continue-text" {
  text = <<-PROMPT
Continue the text in the same style, tone, voice, and format. Previous fragment:

{clipboard}

Instruction:
{recognized_text}

Return only the continuation.
PROMPT
}
template "clipboard" {
  text = <<-PROMPT
Clipboard text:
<clipboard>
{clipboard}
</clipboard>

User task:
{recognized_text}

Return only the result.
PROMPT
}
