# Copy this file beside the GoDict executable and replace or export its credentials.
speech {
  api_key          = "%api_key%"
  folder_id        = "%folder_id%"
  default_language = "Auto"
  languages = {
    Auto    = "auto"
    Russian = "ru-RU"
    English = "en-US"
  }
}

model "gpt" {
  model_name = "gpt-5.5"
  base_url   = "https://api.openai.com/v1"
  api_key    = "%OPENAI_API_KEY%"
  params = { reasoning = { effort = "none" } }
}

model "fast" {
  model_name = "gpt-5.4-mini"
  base_url   = "https://api.openai.com/v1"
  api_key    = "%OPENAI_API_KEY%"
  params = { reasoning = { effort = "none" } }
}

model "cheap" {
  model_name = "gpt-5.4-nano"
  base_url   = "https://api.openai.com/v1"
  api_key    = "%OPENAI_API_KEY%"
  params = { reasoning = { effort = "none" } }
}

model "yagpt" {
  model_name = "gpt://%folder_id%/yandexgpt-5.1"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
}

model "yagpt-pro" {
  model_name = "gpt://%folder_id%/yandexgpt-5-pro"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
}

model "qwen" {
  model_name = "gpt://%folder_id%/qwen3.6-35b-a3b"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
  default    = true
}

model "qwen3" {
  model_name = "gpt://%folder_id%/qwen3-235b-a22b-fp8"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
}

model "deepseek" {
  model_name = "gpt://%folder_id%/deepseek-v4-flash"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
}

model "alice" {
  model_name = "gpt://%folder_id%/aliceai-llm"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
}

model "alice-flash" {
  model_name = "gpt://%folder_id%/aliceai-llm-flash"
  base_url   = "https://ai.api.cloud.yandex.net/v1"
  api_key    = "%api_key%"
  project    = "%folder_id%"
}

template "correct" {
  text = <<-PROMPT
Correct typographical and punctuation errors in the dictated text below. Preserve its meaning and language. Return only the corrected text.

{recognized_text}
PROMPT
}

template "professional" {
  text = <<-PROMPT
Turn the dictated content below into a professional editor's text. First determine the clearest structure and presentation, then write a polished, coherent final text. Preserve factual claims; do not mention this instruction or your planning.

{recognized_text}
PROMPT
}
